# Port the Express server listens on
PORT=4000

# MongoDB connection string (local or Atlas)
MONGO_URI=mongodb://localhost:27017/companygrow

# Secret used to sign/verify JWT auth tokens
JWT_SECRET=replace_with_a_long_random_string

# Stripe secret key (server-side) - get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# URL of the frontend app, used for Stripe checkout redirect URLs
CLIENT_URL=http://localhost:3000

# n8n production webhook URL that fires when a manager approves a badge (optional)
N8N_BADGE_APPROVED_WEBHOOK_URL=http://localhost:5678/webhook/badge-approved

# n8n production webhook URL that fires when a user is assigned to a project (optional)
# Fans out inside n8n to: Send Email, Slack message, Google Sheets append row
N8N_PROJECT_ASSIGNED_WEBHOOK_URL=http://localhost:5678/webhook/project-assigned-automation
